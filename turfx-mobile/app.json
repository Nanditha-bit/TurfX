{
  "expo": {
    "name": "TurfX",
    "slug": "turfx-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.turfx.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TurfX needs camera access to scan booking QR codes at venues.",
        "NSMicrophoneUsageDescription": "Microphone access is not used by this app.",
        "NSNotificationUsageDescription": "TurfX needs to send you booking confirmations and reminders."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.turfx.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "TurfX needs camera access to scan booking QR codes at venues."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#084734"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a472fe76-2ec4-4a00-8be9-0586153cdbc1"
      }
    },
    "owner": "doggesppokk"
  }
}
