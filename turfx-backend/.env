# Server
PORT=5000
ENVIRONMENT=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=turfx_db
DB_USER=postgres
DB_PASSWORD=12345678

# JWT
JWT_SECRET=turfx_super_secret_jwt_key_2024_production_ready
JWT_ALGORITHM=HS256
JWT_EXPIRES_DAYS=30

# Razorpay (replace with live keys for production)
RAZORPAY_KEY_ID=rzp_test_demo_key
RAZORPAY_KEY_SECRET=demo_secret_key

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=TurfX <noreply@turfx.in>

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Admin seed credentials
ADMIN_PHONE=+919999999999
ADMIN_PASSWORD=admin@123
